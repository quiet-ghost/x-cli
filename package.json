{
  "name": "x-cli",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.5",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/quietghost/x-cli"
  },
  "scripts": {
    "dev": "XCLI_VERSION=dev bun --preload @opentui/solid/preload src/index.tsx",
    "start": "bun --preload @opentui/solid/preload src/index.tsx",
    "build:release": "bun run script/build.ts",
    "build:single": "bun run script/build.ts --single",
    "publish:release": "bun run script/publish.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@opentui/core": "0.1.96",
    "@opentui/solid": "0.1.96",
    "smol-toml": "1.3.4",
    "solid-js": "1.9.11",
    "twitter-text": "^3.1.0",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  }
}
